# Copiá este archivo a .env y completá con los datos de tu proyecto Supabase
# (Dashboard > Settings > API). La anon key es pública por diseño: la seguridad
# la dan las políticas RLS. NUNCA pongas acá la service_role key.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY
